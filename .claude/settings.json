{
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "*",
        "hooks": [
          { "type": "command", "command": "python3 scripts/debug/hook_handler.py" }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "*",
        "hooks": [
          { "type": "command", "command": "python3 scripts/debug/hook_handler.py" }
        ]
      }
    ],
    "SubagentStop": [
      { "hooks": [ { "type": "command", "command": "python3 scripts/debug/hook_handler.py" } ] }
    ],
    "Stop": [
      { "hooks": [ { "type": "command", "command": "python3 scripts/debug/hook_handler.py" } ] }
    ],
    "SessionEnd": [
      { "hooks": [ { "type": "command", "command": "python3 scripts/debug/hook_handler.py" } ] }
    ]
  }
}
