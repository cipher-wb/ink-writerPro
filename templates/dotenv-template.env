# Ink Writer 全局 API 配置
#
# 落盘位置（推荐）：~/.claude/ink-writer/.env
# 一次配置，所有小说项目共用。
#
# 你要填的只有 2 个 key（其余默认值不用改）：
#   1. EMBED_API_KEY   ← ModelScope token（免费注册 https://modelscope.cn）
#   2. RERANK_API_KEY  ← Jina API key（免费注册 https://jina.ai）

# ═══════════════════════════════════════════
# Embedding API（语义搜索引擎，写每章时用来回想前文/设定）
# ═══════════════════════════════════════════
EMBED_BASE_URL=https://api-inference.modelscope.cn/v1
EMBED_MODEL=Qwen/Qwen3-Embedding-8B
EMBED_API_KEY=ms-在此处粘贴你的 ModelScope token

# ═══════════════════════════════════════════
# Rerank API（搜索结果重排序，让相关度更准）
# ═══════════════════════════════════════════
RERANK_BASE_URL=https://api.jina.ai/v1
RERANK_MODEL=jina-reranker-v3
RERANK_API_KEY=jina_在此处粘贴你的 Jina key
